  missionDescriptionChinese: "\u53D6\u60A6\u6240\u6709\u4EBA\u662F\u4E0D\u53EF\u80FD\u7684\uFF0C\u8BA9\u6240\u6709\u4EBA\u6050\u60E7\u5374\u8981\u7B80\u5355\u5F97\u591A\u3002\u6211\u4EEC\u5E94\u8BE5\u8BA9\u58EB\u5175\u4EEC\u575A\u5B88\u9635\u5730\uFF0C\u8FD9\u6837\u6211\u4EEC\u7684\u90BB\u5C45\u5C31\u4F1A\u6301\u7EED\u611F\u53D7\u5230\u5A01\u80C1\u3002"
