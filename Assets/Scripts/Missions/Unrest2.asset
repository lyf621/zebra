  missionDescriptionChinese: "\u6211\u4EEC\u5BF9\u5F85\u519B\u961F\u5DF2\u7ECF\u8DB3\u591F\u6177\u6168\u4E86\u3002\u6211\u4EEC\u5E94\u8BE5\u6539\u9769\u519B\u961F\u7ED3\u6784\u3001\u589E\u5F3A\u516C\u7235\u7684\u63A7\u5236\u529B\uFF0C\u8BA9\u4ED6\u4EEC\u6CA1\u6709\u80FD\u529B\u4E3A\u4E86\u6EE1\u8DB3\u79C1\u6B32\u5E72\u51FA\u4E00\u4E9B\u8FC7\u4E8E\u6FC0\u8FDB\u9C81\u83BD\u7684\u4E8B\u6765\u3002"
