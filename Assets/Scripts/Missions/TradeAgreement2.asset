  missionDescriptionChinese: "\u5728\u5806\u79EF\u5982\u5C71\u7684\u6587\u4EF6\u91CC\u9690\u85CF\u51E0\u4E2A\u6F0F\u6D1E\u3002\u7B49\u5230\u4ED6\u4EEC\u7EC8\u4E8E\u610F\u8BC6\u5230\u9677\u9631\u5B58\u5728\u7684\u65F6\u5019\uFF0C\u6211\u4EEC\u65E9\u5C31\u4ECE\u4ED6\u4EEC\u624B\u91CC\u8D5A\u5230\u6210\u5428\u7684\u91D1\u5E01\u4E86\uFF0C\u5BF9\u6B64\u4ED6\u4EEC\u4EC0\u4E48\u90FD\u505A\u4E0D\u4E86\uFF01"
