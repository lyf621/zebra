  m_Name: Harvest
  m_EditorClassIdentifier: Assembly-CSharp::EventSO
  eventTitle: Harvest!
  eventDescription: The realm is seeing a fine harvest this season, but we're facing
    a shortage of farmhands. Dismissing some of our soldiers is a practical choice.
    But we can always squeeze more out of the workers we now have...
  eventTitleChinese: "\u4E30\u6536\uFF01"
  eventDescriptionChinese: "\u9886\u5730\u5728\u672C\u5B63\u5EA6\u7684\u6536\u83B7\u76F8\u5F53\u4E0D\u9519\uFF0C\u95EE\u9898\u662F\u6211\u4EEC\u6B63\u9762\u4E34\u519C\u5E84\u52B3\u52A8\u529B\u77ED\u7F3A\u3002\u89E3\u6563\u4E00\u90E8\u5206\u58EB\u5175\u662F\u4E00\u4E2A\u52A1\u5B9E\u7684\u9009\u62E9\u3002\u4F46\u6211\u4EEC\u603B\u662F\u53EF\u4EE5\u4ECE\u73B0\u6709\u5DE5\u4EBA\u8EAB\u4E0A\u69A8\u51FA\u66F4\u591A\u4EF7\u503C\u2026\u2026"
  availableOptions:
  - buttonText: Dismiss the Army
    buttonTextChinese: "\u89E3\u6563\u90E8\u961F"
    immediateEffect:
