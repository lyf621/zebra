  m_Name: TradeAgreement
  m_EditorClassIdentifier: Assembly-CSharp::EventSO
  eventTitle: Trade Agreement!
  eventDescription: The Aristocrats reached out to us, offering us a trade agreement.
    It seems like we have gained their trust. We could draft a fair agreement, or
    we could exploit their trust and optimize profits.
  eventTitleChinese: "\u8D38\u6613\u534F\u5B9A\uFF01"
  eventDescriptionChinese: "\u5927\u8D35\u65CF\u6B63\u5728\u4E0E\u6211\u4EEC\u63A5\u89E6\uFF0C\u5411\u6211\u4EEC\u63D0\u4F9B\u4E86\u4E00\u4EFD\u8D38\u6613\u534F\u5B9A\u3002\u770B\u6765\u6211\u4EEC\u4F3C\u4E4E\u5DF2\u7ECF\u53D6\u5F97\u4E86\u4ED6\u4EEC\u7684\u4FE1\u4EFB\u3002\u6211\u4EEC\u53EF\u4EE5\u8D77\u8349\u4E00\u4EFD\u516C\u5E73\u7684\u534F\u8BAE\uFF0C\u4E5F\u53EF\u4EE5\u5229\u7528\u4ED6\u4EEC\u7684\u4FE1\u4EFB\u6700\u5927\u5316\u81EA\u5DF1\u7684\u5229\u6DA6\u3002"
  availableOptions:
  - buttonText: Fair Trade
    buttonTextChinese: "\u516C\u5E73\u8D38\u6613"
    immediateEffect:
      gold: 0
      po: 0
      ms: 0
