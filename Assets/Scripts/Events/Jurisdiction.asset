  m_Name: Jurisdiction
  m_EditorClassIdentifier: Assembly-CSharp::EventSO
  eventTitle: Jurisdiction Rivalry!
  eventDescription: The King found an ancient document claiming the crown's jurisdiction
    over a part of our realm. Direct conflict with the King is not an available option,
    but giving in completely will be costly as well.
  eventTitleChinese: "\u6CBB\u6743\u4E89\u7AEF\uFF01"
  eventDescriptionChinese: "\u56FD\u738B\u627E\u5230\u4E00\u4EFD\u53E4\u8001\u7684\u6587\u4EF6\uFF0C\u5BA3\u79F0\u738B\u5BA4\u5BF9\u6211\u4EEC\u7684\u4E00\u90E8\u5206\u9886\u571F\u4EAB\u6709\u7BA1\u8F96\u6743\u3002\u4E0E\u56FD\u738B\u6B63\u9762\u51B2\u7A81\u6839\u672C\u4E0D\u662F\u53EF\u9009\u9879\uFF0C\u4F46\u5F7B\u5E95\u7684\u653E\u5F03\u548C\u59A5\u534F\u4E5F\u4F1A\u4EE4\u6211\u4EEC\u635F\u5931\u60E8\u91CD\u3002"
  availableOptions:
  - buttonText: Compromise
    buttonTextChinese: "\u59A5\u534F"
    immediateEffect:
      gold: 0
      po: 0
      ms: 0
      al: 0
      kr: 0
