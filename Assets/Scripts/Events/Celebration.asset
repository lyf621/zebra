  eventTitleChinese: "\u6B22\u5E86\uFF01"
  eventDescriptionChinese: "\u4EBA\u6C11\u5BF9\u6211\u4EEC\u7684\u6CBB\u7406\u76F8\u5F53\u6EE1\u610F\u3002\u4ED6\u4EEC\u6253\u7B97\u7EC4\u7EC7\u4E00\u573A\u5E86\u5178\u6765\u8868\u8FBE\u4ED6\u4EEC\u7684\u611F\u6FC0\u4E4B\u60C5\u3002\u4E5F\u8BB8\u6211\u4EEC\u5E94\u8BE5\u52A0\u5165\uFF1F"
  availableOptions:
