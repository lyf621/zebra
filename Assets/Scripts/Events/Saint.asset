  m_Name: Saint
  m_EditorClassIdentifier: Assembly-CSharp::EventSO
  eventTitle: Saint?
  eventDescription: Farmers claim that they found a "saint" living in the woods.
    We could request the church to confirm this claim, but the result might upset
    those farmers. On the other hand,  acknowledging his sacred identity by ourselves
    will please the peasants for sure.
  eventTitleChinese: "\u5723\u4EBA\uFF1F"
  eventDescriptionChinese: "\u519C\u6C11\u5BA3\u79F0\u4ED6\u4EEC\u53D1\u73B0\u4E86\u4E00\u4F4D\u9690\u5C45\u5728\u6811\u6797\u4E2D\u7684\u5723\u5F92\u3002
    \u6211\u4EEC\u53EF\u4EE5\u8BF7\u6C42\u6559\u4F1A\u786E\u8BA4\u8FD9\u4EFD\u5BA3\u79F0\uFF0C\u4F46\u7ED3\u679C\u6050\u6015\u8981\u626B\u519C\u6C11\u7684\u5174\u3002\u53E6\u4E00\u65B9\u9762\uFF0C\u6211\u4EEC\u53EF\u4EE5\u81EA\u884C\u627F\u8BA4\u4ED6\u7684\u795E\u5723\u8EAB\u4EFD\uFF0C\u8FD9\u65E0\u7591\u4F1A\u9F13\u821E\u5E73\u6C11\u4EEC\u3002 "
  availableOptions:
  - buttonText: Report to the Church
    buttonTextChinese: "\u62A5\u544A\u6559\u4F1A"
    immediateEffect:
