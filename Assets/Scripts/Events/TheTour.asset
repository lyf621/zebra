  eventTitle: The King's Tour!
  eventDescription: The King planned a tour across the Kingdom, our realm included.
    This is our chance to impress him or reap the benefits of our relationship with
    him.
  eventTitleChinese: "\u56FD\u738B\u7684\u5DE1\u6E38\uFF01"
  eventDescriptionChinese: "\u56FD\u738B\u89C4\u5212\u4E86\u4E00\u573A\u6A2A\u7A7F\u738B\u56FD\u7684\u8FC5\u6E38\uFF0C\u6211\u4EEC\u7684\u9886\u5730\u4E5F\u5728\u8DEF\u7EBF\u4E2D\u3002\u8FD9\u662F\u6211\u4EEC\u7ED9\u4ED6\u7559\u4E0B\u6DF1\u523B\u5370\u8C61\u7684\u673A\u4F1A\uFF0C\u6216\u8005\u6211\u4EEC\u4E5F\u53EF\u4EE5\u5229\u7528\u4E0E\u738B\u5BA4\u7684\u5173\u7CFB\u8C0B\u53D6\u5229\u76CA\u3002"
  availableOptions:
  - buttonText: Please Him
    buttonTextChinese: "\u53D6\u60A6\u56FD\u738B"
