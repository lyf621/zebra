  m_Name: Corruption
  m_EditorClassIdentifier: Assembly-CSharp::EventSO
  eventTitle: Corruption!
  eventDescription: The city council protested that severe corruption plagued the
    citizens. This is due to our declining authority. We need to address the problem,
    whether by ourselves or with external help.
  eventTitleChinese: "\u8150\u8D25\uFF01"
  eventDescriptionChinese: "\u5E02\u8BAE\u4F1A\u6297\u8BAE\u79F0\u4E25\u91CD\u7684\u8150\u8D25\u95EE\u9898\u6DF1\u6DF1\u56F0\u6270\u7740\u5E02\u6C11\u3002\u8FD9\u662F\u6211\u4EEC\u4E0D\u65AD\u4E0B\u6ED1\u7684\u6743\u5A01\u5BFC\u81F4\u7684\u3002\u6211\u4EEC\u9700\u8981\u89E3\u51B3\u8FD9\u4E2A\u95EE\u9898\uFF0C\u4E0D\u7BA1\u662F\u9760\u6211\u4EEC\u81EA\u5DF1\u8FD8\u662F\u501F\u52A9\u5916\u529B\u3002"
  availableOptions:
