  m_Name: Service
  m_EditorClassIdentifier: Assembly-CSharp::EventSO
  eventTitle: Service!
  eventDescription: The King launched a military operation and asked all noble houses,
    especially your house, to serve in the King's army. We may pay a scutage to avoid
    service at the risk of annoying his majesty, otherwise we must go to war as he
    wishes.
  eventTitleChinese: "\u5175\u5F79\uFF01"
  eventDescriptionChinese: "\u56FD\u738B\u53D1\u52A8\u4E86\u4E00\u573A\u519B\u4E8B\u884C\u52A8\u5E76\u8981\u6C42\u6240\u6709\u8D35\u65CF\u5BB6\u65CF\u2014\u2014\u7279\u522B\u662F\u4F60\u7684\u5BB6\u65CF\u2014\u2014\u5728\u56FD\u738B\u7684\u519B\u56E2\u4E2D\u670D\u5F79\u3002\u6211\u4EEC\u53EF\u4EE5\u5192\u7740\u6FC0\u6012\u965B\u4E0B\u7684\u98CE\u9669\u4ED8\u4E00\u7B14\u5175\u5F79\u514D\u9664\u7A0E\u6765\u907F\u514D\u670D\u5F79\uFF0C\u5426\u5219\u6211\u4EEC\u5C31\u5FC5\u987B\u6309\u7167\u4ED6\u7684\u610F\u613F\u53C2\u6218\u3002"
  availableOptions:
  - buttonText: Service
    buttonTextChinese: "\u519B\u4E8B\u4E49\u52A1"
    immediateEffect:
